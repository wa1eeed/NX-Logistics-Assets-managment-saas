# ============================================================
# .env.example — انسخه إلى .env واملأ القيم. لا تضع .env في git.
# في dev يمكن ترك مفاتيح R2/Resend/Sentry فارغة (تعطيل لطيف).
# ============================================================

# ---- App ----
NODE_ENV=development
API_PORT=3001
WEB_PORT=5173
APP_BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ---- Database (Postgres) — منفذ المضيف 5435 في docker-compose ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/fleet_assets?schema=public

# ---- Auth ----
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---- Seed (حساب السوبر أدمن الأولي) ----
SEED_ADMIN_EMAIL=admin@nx-lam.local
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=System Administrator

# ---- Cloudflare R2 (S3-compatible) ----
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=fleet-assets
R2_SIGNED_URL_TTL=300

# ---- Cloudflare CDN (الأصول العامة فقط) ----
CDN_PUBLIC_BASE_URL=

# ---- Public Web base (روابط العودة بعد الدفع عبر بوابة الدفع) ----
WEB_PUBLIC_URL=http://localhost:5173

# ---- Tap payment gateway ----
# تُدار فعلياً من «بوابة الدفع» في لوحة أدمن المنصّة (PlatformSetting، السر لا يُعاد للواجهة).
# اتركها فارغة → يعمل وضع الساندبوكس في dev.
TAP_SECRET_KEY=
TAP_PUBLIC_KEY=

# ---- Resend (Transactional email) ----
RESEND_API_KEY=
MAIL_FROM="Fleet Assets <no-reply@yourdomain.com>"
# Alerts digest scheduler (only runs when RESEND_API_KEY is set)
ALERTS_DIGEST_INTERVAL_MS=86400000
# Optional: comma-separated override recipients; default = active users with kpis.read
ALERTS_DIGEST_TO=

# ---- Sentry ----
SENTRY_DSN_API=
SENTRY_DSN_WEB=
SENTRY_ENVIRONMENT=development

# ---- Google Maps (تطبيق السائقين — لاحقاً) ----
GOOGLE_MAPS_API_KEY=
