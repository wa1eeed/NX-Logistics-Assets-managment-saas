# ============================================================
# .env.staging.example — copy to .env.staging and fill the secrets.
# Used by deploy/docker-compose.staging.yml (or paste these into Coolify Secrets).
# NEVER commit the real .env.staging.
# ============================================================

# ---- Public URL the browser reaches (used for CORS, payment return links) ----
WEB_PUBLIC_URL=https://staging.your-domain.com
# Host port the web container is published on (Coolify usually proxies this).
WEB_PORT=8080

# ---- Postgres (the compose db service; or set DATABASE_URL directly if using a managed DB) ----
POSTGRES_USER=nxlam
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=fleet_assets

# ---- Auth — generate strong random values (e.g. `openssl rand -hex 32`) ----
JWT_ACCESS_SECRET=change-me-32+chars
JWT_REFRESH_SECRET=change-me-different-32+chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---- First super-admin (seeded once via `db:seed:ci`) ----
SEED_ADMIN_EMAIL=admin@your-domain.com
SEED_ADMIN_PASSWORD=change-me-strong
SEED_ADMIN_NAME=System Administrator

# ---- Cloudflare R2 (file storage). Leave blank to disable uploads gracefully. ----
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=fleet-assets
R2_SIGNED_URL_TTL=300
CDN_PUBLIC_BASE_URL=

# ---- Tap payments — leave blank to use sandbox; real keys are set in the platform admin UI ----
TAP_SECRET_KEY=
TAP_PUBLIC_KEY=

# ---- Resend (transactional email + alert digests). Blank = email disabled. ----
RESEND_API_KEY=
MAIL_FROM="Fleet Assets <no-reply@your-domain.com>"
ALERTS_DIGEST_INTERVAL_MS=86400000
ALERTS_DIGEST_TO=

# ---- Sentry (error tracking) ----
SENTRY_DSN_API=
SENTRY_ENVIRONMENT=staging

# ---- Google Maps (driver app — later) ----
GOOGLE_MAPS_API_KEY=
